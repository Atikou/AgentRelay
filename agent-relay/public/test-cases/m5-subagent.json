{
  "milestone": "M5",
  "feature": "子 Agent",
  "featureId": "m5-subagent",
  "summary": "验证只读子 Agent 角色列表、参数校验与权限边界（运行单条需模型，此处不测成功路径）。",
  "cases": [
    {
      "id": "m5-roles-list",
      "title": "子 Agent 角色列表含三个角色",
      "purpose": "确认 GET /api/subagent/roles 暴露 code_review、test_analyze 与 patch_worker。",
      "method": "GET",
      "path": "/api/subagent/roles",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["roles"],
        "bodyPaths": { "roles.length": 3 }
      }
    },
    {
      "id": "m5-run-empty-task",
      "title": "空 task 返回 400",
      "purpose": "确认子 Agent 运行入口拒绝空任务，避免无意义模型调用。",
      "method": "POST",
      "path": "/api/subagent/run",
      "input": { "role": "code_review", "task": "" },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m5-batch-empty-roles",
      "title": "batch 空 roles 返回 400",
      "purpose": "确认并行派生必须指定至少一个角色。",
      "method": "POST",
      "path": "/api/subagent/batch",
      "input": { "task": "检查代码", "roles": [] },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m5-batch-aggregate-contract",
      "title": "batch 返回结构化 aggregate",
      "purpose": "确认并行子 Agent 成功响应除 summary 外，还返回 aggregate 结构，便于父 Agent 读取共同结论与冲突信息。",
      "method": "POST",
      "path": "/api/subagent/batch",
      "input": {
        "roles": ["code_review", "test_analyze"],
        "task": "检查 README.md 的风险",
        "timeoutMs": 120000
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["runId", "parentTaskId", "results", "summary", "aggregate"],
        "bodyPaths": {
          "results": "array",
          "aggregate.conflicts": "array",
          "aggregate.mergedAnswer": "string"
        }
      }
    },
    {
      "id": "m5-batch-conflict-fields",
      "title": "aggregate 暴露冲突检测字段",
      "purpose": "确认 aggregate 至少包含 status/commonFindings/conflicts，供测试台和父 Agent 判断是否需要人工复核。",
      "method": "POST",
      "path": "/api/subagent/batch",
      "input": {
        "roles": ["code_review", "test_analyze"],
        "task": "分别审查当前改动是否存在相反结论",
        "timeoutMs": 120000
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["aggregate"],
        "bodyPaths": {
          "aggregate.status": "string",
          "aggregate.commonFindings": "array",
          "aggregate.conflicts": "array"
        }
      }
    },
    {
      "id": "m5-run-invalid-grant",
      "title": "授予 write 权限被拒绝",
      "purpose": "验证父 Agent 不能为只读子 Agent 授予 write 等非允许权限。",
      "method": "POST",
      "path": "/api/subagent/run",
      "input": {
        "role": "code_review",
        "task": "x",
        "grantedPermissions": ["write"]
      },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m5-config-subagent-smart-routing",
      "title": "GET /api/config 暴露 subAgentSmartRouting",
      "purpose": "确认子 Agent 默认 chat 已接入 SmartModelRouter，与 Agent 路由一致。",
      "method": "GET",
      "path": "/api/config",
      "input": {},
      "expect": {
        "status": 200,
        "bodyPaths": {
          "capabilities.subAgentSmartRouting": true
        }
      }
    },
    {
      "id": "m5-run-unknown-client",
      "title": "未知 clientName 返回 404",
      "purpose": "确认子 Agent 显式 clientName 校验不受 Smart 路由影响。",
      "method": "POST",
      "path": "/api/subagent/run",
      "input": { "role": "code_review", "task": "review", "clientName": "missing" },
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m5-dispatch-subagent-tool-listed",
      "title": "GET /api/tools 含 dispatch_subagent",
      "purpose": "确认主 Agent 与子 Agent 共用注册表时，dispatch_subagent 作为内置工具对外暴露。",
      "method": "GET",
      "path": "/api/tools",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["dispatch_subagent"]
      }
    },
    {
      "id": "m5-dispatch-subagent-doc-loop",
      "title": "对话循环文档记录 dispatch_subagent",
      "purpose": "确认对话循环文档说明主 Agent 在 ReAct 循环内可调用 dispatch_subagent 派生只读子 Agent。",
      "method": "GET",
      "path": "/api/docs/content?slug=对话循环",
      "input": null,
      "expect": {
        "status": 200,
        "bodyPaths": {
          "markdown": "string"
        },
        "bodyContains": ["dispatch_subagent", "子 Agent"]
      }
    },
    {
      "id": "m5-roles-include-patch-worker",
      "title": "GET /api/subagent/roles 含 patch_worker",
      "purpose": "确认写权限子 Agent 角色 patch_worker 已暴露且 allowedPermissions 含 read+write。",
      "method": "GET",
      "path": "/api/subagent/roles",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["patch_worker", "read", "write"]
      }
    },
    {
      "id": "m5-subagent-notification-doc",
      "title": "子 Agent 文档记录完成通知",
      "purpose": "确认文档说明子 Agent 完成后写入 NotificationQueue（source=subagent）供主 Agent 安全点消费。",
      "method": "GET",
      "path": "/api/docs/content?slug=子Agent",
      "input": null,
      "expect": {
        "status": 200,
        "bodyPaths": {
          "markdown": "string"
        },
        "bodyContains": ["NotificationQueue", "subagent", "maxDispatchDepth"]
      }
    },
    {
      "id": "m5-write-conflict-doc",
      "title": "子 Agent 文档记录写入冲突检测",
      "purpose": "确认文档说明 detectWriteConflicts / aggregate.writeConflicts 检测多子 Agent 写入同一文件。",
      "method": "GET",
      "path": "/api/docs/content?slug=子Agent",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["writeConflicts", "writeConflictMerge", "同一文件"]
      }
    },
    {
      "id": "m5-arbitrate-conflicts-doc",
      "title": "子 Agent 文档记录模型仲裁",
      "purpose": "确认 batch / dispatch_subagent 可通过 arbitrateConflicts 启用模型仲裁复核。",
      "method": "GET",
      "path": "/api/docs/content?slug=子Agent",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["arbitrateConflicts", "arbitration", "模型仲裁"]
      }
    },
    {
      "id": "m5-auto-merge-writes-doc",
      "title": "子 Agent 文档记录 autoMergeWrites",
      "purpose": "确认 batch / dispatch_subagent 支持 autoMergeWrites 自动三路补丁合并，且 aggregate.writeMerges 有说明。",
      "method": "GET",
      "path": "/api/docs/content?slug=子Agent",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["autoMergeWrites", "writeMerges", "三路"]
      }
    },
    {
      "id": "m5-api-spec-batch-merge-fields",
      "title": "api-spec 暴露 batch 合并字段",
      "purpose": "确认 OpenAPI SubAgentBatchRequest 含 autoMergeWrites，SubAgentAggregate 含 writeMerges。",
      "method": "GET",
      "path": "/api/api-spec",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["autoMergeWrites", "writeMerges", "SubAgentWriteMergeAttempt"]
      }
    },
    {
      "id": "m5-subagent-cancel-missing-id",
      "title": "cancel 缺少 subAgentId 返回 400",
      "purpose": "确认显式取消入口校验 subAgentId，避免误操作。",
      "method": "POST",
      "path": "/api/subagent/cancel",
      "input": {},
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m5-subagent-cancel-not-running",
      "title": "cancel 非运行中 subAgentId 返回 404",
      "purpose": "确认对不存在或已结束的 subAgentId 取消返回 404。",
      "method": "POST",
      "path": "/api/subagent/cancel",
      "input": { "subAgentId": "00000000-0000-4000-8000-000000000000" },
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m5-subagent-cancel-doc",
      "title": "子 Agent 文档记录显式 cancel",
      "purpose": "确认文档说明 POST /api/subagent/cancel 与 running 查询。",
      "method": "GET",
      "path": "/api/docs/content?slug=子Agent",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["/api/subagent/cancel", "subAgentId", "running"]
      }
    },
    {
      "id": "m5-write-file-pick-doc",
      "title": "子 Agent 文档记录 write_file 选版",
      "purpose": "确认文档说明 writeFilePickStrategy 与仲裁 WRITE_PICK 自动选版。",
      "method": "GET",
      "path": "/api/docs/content?slug=子Agent",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["writeFilePickStrategy", "WRITE_PICK", "write_file"]
      }
    },
    {
      "id": "m5-dispatch-input-normalization-doc",
      "title": "dispatch_subagent 文档记录错参归一化",
      "purpose": "确认文档说明 dispatch_subagent 会归一化 task 数组、空对象 context、角色别名和 null 选项，降低模型工具调用错误。",
      "method": "GET",
      "path": "/api/docs/content?slug=子Agent",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["归一化", "task", "context", "writeFilePickStrategy"]
      }
    },
    {
      "id": "m5-dispatch-final-convergence-doc",
      "title": "dispatch_subagent 文档记录三结果收敛",
      "purpose": "确认文档说明主 Agent 已收集 3 个成功子 Agent 结果后会阻止继续派生并要求输出 final。",
      "method": "GET",
      "path": "/api/docs/content?slug=子Agent",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["3 个", "dispatch_subagent", "final"]
      }
    }
  ]
}
