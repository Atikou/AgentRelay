{
  "milestone": "M3",
  "feature": "任务模式",
  "featureId": "m3-task",
  "summary": "验证 TaskRunner dry-run 入口对 PlanSchema 的校验。",
  "cases": [
    {
      "id": "m3-task-invalid-plan",
      "title": "非法 plan 格式返回 400",
      "purpose": "确认任务模式在计划 JSON 不符合 zod Schema 时立即 400，不进入状态机执行。",
      "method": "POST",
      "path": "/api/task/dry-run",
      "input": { "plan": { "not": "a plan" } },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m3-task-run-invalid-plan",
      "title": "真实执行入口非法 plan 返回 400",
      "purpose": "确认 /api/task/run 与 dry-run 使用同一 PlanSchema 校验，非法计划不会进入工具执行层。",
      "method": "POST",
      "path": "/api/task/run",
      "input": { "plan": { "not": "a plan" }, "autoConfirm": false },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m3-task-dry-run-valid",
      "title": "合法 dry-run 返回 runId 与 taskId",
      "purpose": "确认 Orchestrator 执行 task dry-run 时会创建 Run 与 Task，并返回可追踪的 runId/taskId。",
      "method": "POST",
      "path": "/api/task/dry-run",
      "input": {
        "autoConfirm": true,
        "plan": {
          "goal": "网页用例 dry-run",
          "steps": [
            {
              "id": "s1",
              "title": "读取状态",
              "description": "只读检查",
              "requiredPermissions": ["read"],
              "status": "pending"
            },
            {
              "id": "s2",
              "title": "汇总结果",
              "description": "依赖第一步",
              "requiredPermissions": ["read"],
              "dependsOn": ["s1"],
              "status": "pending"
            }
          ]
        }
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["runId", "taskId", "plan"],
        "bodyPaths": {
          "plan.steps": "array"
        }
      }
    },
    {
      "id": "m3-task-dry-run-confirm-blocked",
      "title": "需要确认且未 autoConfirm 的步骤会阻塞",
      "purpose": "覆盖确认门边界：当步骤 needsConfirmation=true 且未开启 autoConfirm 时，TaskRunner 应返回 blocked 状态而不是继续执行。",
      "method": "POST",
      "path": "/api/task/dry-run",
      "input": {
        "autoConfirm": false,
        "plan": {
          "goal": "确认门阻塞",
          "steps": [
            {
              "id": "confirm-1",
              "title": "需要人工确认",
              "description": "模拟写操作前确认",
              "requiredPermissions": ["write"],
              "needsConfirmation": true,
              "status": "pending"
            }
          ]
        }
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["runId", "taskId", "plan"],
        "bodyPaths": {
          "plan.steps": "array"
        }
      }
    },
    {
      "id": "m3-task-blocked-branch-dry-run",
      "title": "阻塞分支时独立步骤仍 dry-run 完成",
      "purpose": "确认某步 blocked（确认门）后，无依赖的其他步骤仍 completed，依赖阻塞步的后续为 blocked。",
      "method": "POST",
      "path": "/api/task/dry-run",
      "input": {
        "autoConfirm": false,
        "plan": {
          "goal": "阻塞分支",
          "steps": [
            {
              "id": "block",
              "title": "需确认写",
              "description": "应 blocked",
              "requiredPermissions": ["write"],
              "needsConfirmation": true,
              "status": "pending"
            },
            {
              "id": "free",
              "title": "只读分支",
              "description": "无依赖应完成",
              "requiredPermissions": ["read"],
              "status": "pending"
            },
            {
              "id": "after",
              "title": "依赖阻塞步",
              "description": "应因 block 而 blocked",
              "requiredPermissions": ["read"],
              "dependsOn": ["block"],
              "status": "pending"
            }
          ]
        }
      },
      "expect": {
        "status": 200,
        "bodyPaths": {
          "plan.steps[0].status": "blocked",
          "plan.steps[1].status": "completed",
          "plan.steps[2].status": "blocked"
        }
      }
    },
    {
      "id": "m3-task-blocked-sibling-pair",
      "title": "并行双分支其一 blocked 另一 completed",
      "purpose": "简化两步骤场景：无 dependsOn 的只读分支在写分支 blocked 后仍应 completed。",
      "method": "POST",
      "path": "/api/task/dry-run",
      "input": {
        "autoConfirm": false,
        "plan": {
          "goal": "并行双分支",
          "steps": [
            {
              "id": "block",
              "title": "需确认写",
              "requiredPermissions": ["write"],
              "needsConfirmation": true,
              "status": "pending"
            },
            {
              "id": "free",
              "title": "只读",
              "requiredPermissions": ["read"],
              "status": "pending"
            }
          ]
        }
      },
      "expect": {
        "status": 200,
        "bodyPaths": {
          "plan.steps[0].status": "blocked",
          "plan.steps[1].status": "completed"
        }
      }
    },
    {
      "id": "m3-task-rollback-on-failure",
      "title": "rollbackOnFailure 时失败任务返回 rollback 摘要",
      "purpose": "确认任务真实执行中某步失败后，显式开启 rollbackOnFailure 会按 Run 内 changeId 逆序补偿并返回 attempted/restored。",
      "method": "POST",
      "path": "/api/task/run",
      "input": {
        "autoConfirm": true,
        "rollbackOnFailure": true,
        "plan": {
          "goal": "回滚探测",
          "steps": [
            {
              "id": "w1",
              "title": "写入探测文件",
              "description": "产生可回滚的 changeId",
              "requiredPermissions": ["write"],
              "status": "pending",
              "tool": "write_file",
              "toolInput": {
                "path": "test-cases/rollback-probe.txt",
                "content": "probe",
                "backup": true
              }
            },
            {
              "id": "f1",
              "title": "故意失败",
              "description": "读取不存在文件以触发 failed",
              "requiredPermissions": ["read"],
              "status": "pending",
              "tool": "read_file",
              "toolInput": { "path": "__rollback_probe_missing__.txt" }
            }
          ]
        }
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["runId", "taskId", "plan", "rollback"],
        "bodyPaths": {
          "rollback.attempted": "number",
          "plan.steps[1].status": "failed"
        }
      }
    },
    {
      "id": "m3-task-dag-dry-run",
      "title": "dependsOn 链 dry-run 全部完成",
      "purpose": "确认 TaskRunner 按依赖图调度：s2 依赖 s1、s3 依赖 s2 时 dry-run 三步均为 completed。",
      "method": "POST",
      "path": "/api/task/dry-run",
      "input": {
        "autoConfirm": true,
        "plan": {
          "goal": "DAG dry-run",
          "steps": [
            {
              "id": "s1",
              "title": "第一步",
              "description": "无依赖",
              "requiredPermissions": ["read"],
              "status": "pending"
            },
            {
              "id": "s2",
              "title": "第二步",
              "description": "依赖 s1",
              "requiredPermissions": ["read"],
              "dependsOn": ["s1"],
              "status": "pending"
            },
            {
              "id": "s3",
              "title": "第三步",
              "description": "依赖 s2",
              "requiredPermissions": ["read"],
              "dependsOn": ["s2"],
              "status": "pending"
            }
          ]
        }
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["runId", "taskId", "plan"],
        "bodyPaths": {
          "plan.steps[0].status": "completed",
          "plan.steps[1].status": "completed",
          "plan.steps[2].status": "completed"
        }
      }
    },
    {
      "id": "m3-task-dag-parallel-dry-run",
      "title": "并行波次 dry-run 菱形依赖",
      "purpose": "确认 s1/s2 无依赖可同波完成，s3 依赖二者在汇聚后 completed。",
      "method": "POST",
      "path": "/api/task/dry-run",
      "input": {
        "autoConfirm": true,
        "plan": {
          "goal": "DAG parallel dry-run",
          "steps": [
            {
              "id": "s1",
              "title": "分支 A",
              "description": "无依赖",
              "requiredPermissions": ["read"],
              "status": "pending"
            },
            {
              "id": "s2",
              "title": "分支 B",
              "description": "无依赖",
              "requiredPermissions": ["read"],
              "status": "pending"
            },
            {
              "id": "s3",
              "title": "汇聚",
              "description": "依赖 s1 与 s2",
              "requiredPermissions": ["read"],
              "dependsOn": ["s1", "s2"],
              "status": "pending"
            }
          ]
        }
      },
      "expect": {
        "status": 200,
        "bodyPaths": {
          "plan.steps[2].status": "completed"
        }
      }
    },
    {
      "id": "m3-task-rollback-default-off",
      "title": "默认不开启 rollbackOnFailure",
      "purpose": "确认未传 rollbackOnFailure 时响应不含 rollback 字段，避免意外抹除部分成功副作用。",
      "method": "POST",
      "path": "/api/task/run",
      "input": {
        "autoConfirm": true,
        "plan": {
          "goal": "默认不回滚",
          "steps": [
            {
              "id": "w1",
              "title": "写入",
              "description": "写探测文件",
              "requiredPermissions": ["write"],
              "status": "pending",
              "tool": "write_file",
              "toolInput": {
                "path": "test-cases/rollback-default-off.txt",
                "content": "keep",
                "backup": true
              }
            },
            {
              "id": "f1",
              "title": "失败",
              "description": "读不存在文件",
              "requiredPermissions": ["read"],
              "status": "pending",
              "tool": "read_file",
              "toolInput": { "path": "__rollback_default_off__.txt" }
            }
          ]
        }
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["runId", "taskId", "plan"],
        "bodyPaths": {
          "plan.steps[1].status": "failed"
        }
      }
    },
    {
      "id": "m3-task-fallback-skipped-when-complete",
      "title": "全完成时即使开启 fallback 也不返回 modeFallback",
      "purpose": "确认 fallbackToPlanOnUncertainty 仅在 blocked/failed 时触发；全部 completed 时不附带 modeFallback。",
      "method": "POST",
      "path": "/api/task/dry-run",
      "input": {
        "autoConfirm": true,
        "fallbackToPlanOnUncertainty": true,
        "plan": {
          "goal": "顺利完成",
          "steps": [
            {
              "id": "s1",
              "title": "只读步骤",
              "requiredPermissions": ["read"],
              "status": "pending"
            }
          ]
        }
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["runId", "taskId", "plan"],
        "bodyPaths": {
          "plan.steps[0].status": "completed"
        }
      }
    },
    {
      "id": "m3-task-blocked-no-fallback-by-default",
      "title": "阻塞步骤默认不回退计划模式",
      "purpose": "未传 fallbackToPlanOnUncertainty 时，即使步骤 blocked 也不应调用 Planner（响应无 modeFallback）。",
      "method": "POST",
      "path": "/api/task/dry-run",
      "input": {
        "autoConfirm": false,
        "plan": {
          "goal": "默认不回退",
          "steps": [
            {
              "id": "s1",
              "title": "需确认写",
              "requiredPermissions": ["write"],
              "needsConfirmation": true,
              "status": "pending"
            }
          ]
        }
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["runId", "taskId", "plan"],
        "bodyPaths": {
          "plan.steps[0].status": "blocked"
        }
      }
    }
  ]
}
