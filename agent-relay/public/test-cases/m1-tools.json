{
  "milestone": "M1",
  "feature": "工具系统",
  "featureId": "m1-tools",
  "summary": "验证 ToolRegistry 暴露的内置工具、安全写入/补丁/回滚、命令风险拦截与相关文件定位工具。",
  "cases": [
    {
      "id": "m1-tools-list",
      "title": "工具列表包含 14 个内置工具",
      "purpose": "确认注册表暴露 read/list/search/write/patch/diff/backup/rollback/shell/git 与相关文件定位工具。",
      "method": "GET",
      "path": "/api/tools",
      "input": null,
      "expect": {
        "status": 200,
        "bodyPaths": { "tools.length": 14 },
        "bodyContainsNames": [
          "read_file",
          "write_file",
          "apply_patch",
          "shell_run",
          "list_files",
          "search_text",
          "project_scan",
          "locate_relevant_files",
          "context_pack",
          "git_status",
          "git_diff"
        ]
      }
    },
    {
      "id": "m1-tools-error-category-capability",
      "title": "配置暴露工具错误分类能力",
      "purpose": "确认服务端声明工具失败会返回 category，便于前端区分用户错误、权限错误、环境错误、临时错误和未知错误。",
      "method": "GET",
      "path": "/api/config",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["capabilities"],
        "bodyPaths": {
          "capabilities.toolErrorCategory": true
        }
      }
    },
    {
      "id": "m1-tools-invalid-input-category",
      "title": "非法工具入参返回用户错误分类",
      "purpose": "验证 ToolRegistry 对 zod 入参校验失败返回 code=invalid_input 且 category=user_error。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": { "name": "read_file", "input": {} },
      "expect": {
        "status": 400,
        "bodyPaths": {
          "ok": false,
          "code": "invalid_input",
          "category": "user_error"
        }
      }
    },
    {
      "id": "m1-tools-mock-helper-documented",
      "title": "工具系统文档包含 mock 工具测试辅助",
      "purpose": "确认 mock 工具作为测试专用能力已进入文档站内容，便于后续 AgentLoop/TaskRunner 测试复用。",
      "method": "GET",
      "path": "/api/docs/content?slug=工具系统",
      "input": null,
      "expect": {
        "status": 200,
        "bodyPaths": {
          "slug": "工具系统",
          "markdown": "string"
        }
      }
    },
    {
      "id": "m1-tools-default-registry-excludes-mock",
      "title": "默认工具注册表不暴露 mock 工具",
      "purpose": "验证 mock 工具仅用于测试辅助，不进入生产默认注册表和 /api/tools 工具列表。",
      "method": "GET",
      "path": "/api/tools",
      "input": null,
      "expect": {
        "status": 200,
        "bodyPaths": { "tools.length": 14 },
        "bodyContainsNames": [
          "read_file",
          "write_file",
          "context_pack",
          "shell_run"
        ]
      }
    },
    {
      "id": "m1-tools-read",
      "title": "read_file 读取 package.json 含 sha256",
      "purpose": "验证只读工具返回内容与 sha256，供后续 expectedHash 并发保护。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": { "name": "read_file", "input": { "path": "package.json" } },
      "expect": {
        "status": 200,
        "bodyPaths": { "ok": true, "tool": "read_file", "output.sha256": "string" }
      }
    },
    {
      "id": "m1-tools-apply-patch",
      "title": "apply_patch 唯一匹配替换",
      "purpose": "验证 Agent 首选的安全修改工具可替换唯一片段并返回 changeId。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": {
        "name": "apply_patch",
        "input": {
          "path": "package.json",
          "search": "\"name\": \"agent-relay\"",
          "replace": "\"name\": \"agent-relay\""
        },
        "confirm": true
      },
      "expect": {
        "status": 200,
        "bodyPaths": { "ok": true, "output.changeId": "string" }
      }
    },
    {
      "id": "m1-tools-write-preview",
      "title": "write_file 未确认时返回 patchPreview",
      "purpose": "验证写文件工具在真正落盘前先给出 diff 预览，避免测试台确认门成为盲确认。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": {
        "name": "write_file",
        "input": {
          "path": "data/tmp-preview.txt",
          "content": "preview only\n",
          "createOnly": true
        }
      },
      "expect": {
        "status": 200,
        "bodyPaths": {
          "needsConfirmation": true,
          "preview.kind": "write_file",
          "preview.patchPreview": "string",
          "risk.tier": "medium",
          "risk.category": "file_write"
        }
      }
    },
    {
      "id": "m1-tools-shell-confirm",
      "title": "shell_run 未确认时返回 needsConfirmation",
      "purpose": "验证副作用命令默认走确认门，未传 confirm 时不执行，防止误跑 shell。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": { "name": "shell_run", "input": { "command": "node -v" } },
      "expect": {
        "status": 200,
        "bodyPaths": { "needsConfirmation": true, "tool": "shell_run", "risk.tier": "low", "risk.category": "shell_command" }
      }
    },
    {
      "id": "m1-tools-structured-risk-capability",
      "title": "配置暴露结构化工具风险能力",
      "purpose": "确认服务端声明高风险工具输出会附带统一 risk 结构，便于测试台与审计页展示。",
      "method": "GET",
      "path": "/api/config",
      "input": null,
      "expect": {
        "status": 200,
        "bodyPaths": {
          "capabilities.structuredToolRisk": true
        }
      }
    },
    {
      "id": "m1-tools-shell-ok",
      "title": "shell_run 确认后 node -v 退出码 0",
      "purpose": "确认用户显式 confirm 后安全命令可执行且退出码为 0。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": {
        "name": "shell_run",
        "input": { "command": "node -v" },
        "confirm": true
      },
      "expect": {
        "status": 200,
        "bodyPaths": { "ok": true, "output.exitCode": 0 }
      }
    },
    {
      "id": "m1-tools-dangerous",
      "title": "高风险命令 rm -rf 被拒绝",
      "purpose": "验证 shell_run 拒绝高风险命令，即使 confirm=true 也不得执行。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": {
        "name": "shell_run",
        "input": { "command": "rm -rf /" },
        "confirm": true
      },
      "expect": {
        "status": 400,
        "bodyPaths": { "ok": false }
      }
    },
    {
      "id": "m1-tools-project-scan",
      "title": "project_scan 返回重要文件",
      "purpose": "验证相关文件定位前置扫描可一次返回项目类型、源码根和重要文件，减少低层 list_files 探索。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": { "name": "project_scan", "input": { "root": ".", "maxDepth": 3 } },
      "expect": {
        "status": 200,
        "bodyPaths": {
          "ok": true,
          "tool": "project_scan",
          "output.importantFiles": "array"
        }
      }
    },
    {
      "id": "m1-tools-locate-relevant-files",
      "title": "locate_relevant_files 返回候选文件",
      "purpose": "验证相关文件定位工具能根据目标生成搜索计划并返回 primaryFiles/candidateFiles。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": {
        "name": "locate_relevant_files",
        "input": {
          "goal": "优化 AgentLoop 的相关文件定位流程",
          "possibleSymbols": ["AgentLoop", "ToolRegistry"],
          "limit": 8
        }
      },
      "expect": {
        "status": 200,
        "bodyPaths": {
          "ok": true,
          "output.searchPlan": "object",
          "output.candidateFiles": "array",
          "output.confidence": "number"
        }
      }
    },
    {
      "id": "m1-tools-context-pack",
      "title": "context_pack 打包多个文件",
      "purpose": "验证上下文打包工具能一次读取并摘要多个文件，避免 Agent 连续 read_file。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": {
        "name": "context_pack",
        "input": {
          "files": ["src/agent/AgentLoop.ts", "src/tools/ToolRegistry.ts"],
          "maxFiles": 2,
          "maxTokens": 6000
        }
      },
      "expect": {
        "status": 200,
        "bodyPaths": {
          "ok": true,
          "output.files": "array",
          "output.combinedSummary": "string"
        }
      }
    },
    {
      "id": "m1-tools-git-status",
      "title": "git_status 返回 isRepo",
      "purpose": "确认 git 状态工具可用，Agent 可检查工作区改动。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": { "name": "git_status", "input": {} },
      "expect": {
        "status": 200,
        "bodyPaths": { "ok": true, "output.isRepo": true }
      }
    }
  ]
}
