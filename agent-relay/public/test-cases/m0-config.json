{
  "milestone": "M0",
  "feature": "配置与连通",
  "featureId": "m0-config",
  "summary": "验证多 profile 配置能经 HTTP 正确暴露，供测试台与 CLI 读取。",
  "cases": [
    {
      "id": "m0-config-profile",
      "title": "读取配置含 profile 与 workspaceRoot",
      "purpose": "确认 GET /api/config 返回当前 profile、工作区路径与默认模型，测试台「查看配置」依赖此接口。",
      "method": "GET",
      "path": "/api/config",
      "input": null,
      "expect": {
        "status": 200,
        "bodyPaths": { "profile": "string", "workspaceRoot": "string", "defaultModel": "string" },
        "bodyHasKeys": ["clients", "routing"]
      }
    },
    {
      "id": "m0-config-clients-array",
      "title": "配置返回客户端列表",
      "purpose": "确认配置接口暴露 clients 数组，供模型下拉、路由展示与连通性面板复用。",
      "method": "GET",
      "path": "/api/config",
      "input": null,
      "expect": {
        "status": 200,
        "bodyPaths": { "clients": "array", "routing.strategy": "string" }
      }
    },
    {
      "id": "m0-api-spec",
      "title": "API 规范可访问",
      "purpose": "确认 public/api-spec.json 经静态服务暴露，供 /api-docs 交互参考页加载。",
      "method": "GET",
      "path": "/api-spec.json",
      "input": null,
      "expect": {
        "status": 200,
        "bodyPaths": { "info.title": "string", "paths": "object" },
        "bodyHasKeys": ["openapi", "info", "paths", "components", "tags"]
      }
    },
    {
      "id": "m0-api-docs-page",
      "title": "API 参考页路由",
      "purpose": "确认 GET /api-docs 返回交互参考 HTML，测试台「API 文档 ↗」入口依赖此路由。",
      "method": "GET",
      "path": "/api-docs",
      "input": null,
      "expect": {
        "status": 200,
        "contentTypeIncludes": "text/html",
        "bodyIncludes": ["/api-spec.json", "AgentRelay", "data-url"]
      }
    }
  ]
}
