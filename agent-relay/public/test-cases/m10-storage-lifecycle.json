{
  "milestone": "M7",
  "feature": "数据生命周期与清理",
  "featureId": "m10-storage-lifecycle",
  "summary": "验证存储用量统计、清理预览（dry-run）与安全清理 apply API。",
  "cases": [
    {
      "id": "m10-storage-usage",
      "title": "获取本地存储用量",
      "purpose": "确认可按 trace、timeline、SQLite、cache、temp 等类别查看磁盘占用，便于用户判断是否需要清理。",
      "method": "GET",
      "path": "/api/storage/usage",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["totalBytes", "categories", "generatedAt"]
      }
    },
    {
      "id": "m10-storage-cleanup-preview-safe",
      "title": "安全清理预览不删除文件",
      "purpose": "确认 preview 默认 dry-run，返回 cleanupRunId 与候选动作，但不实际删除 temp/cache。",
      "method": "POST",
      "path": "/api/storage/cleanup/preview",
      "input": {
        "scope": "safe"
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["cleanupRunId", "mode", "summary", "actions"],
        "bodyPaths": {
          "mode": "dry-run"
        }
      }
    },
    {
      "id": "m10-storage-cleanup-apply-missing-preview",
      "title": "未预览直接 apply 返回 404",
      "purpose": "确认清理执行必须先 preview，避免误删；无有效 cleanupRunId 时拒绝 apply。",
      "method": "POST",
      "path": "/api/storage/cleanup/apply",
      "input": {
        "cleanupRunId": "cleanup_nonexistent",
        "confirm": true
      },
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m10-session-purge-no-confirm",
      "title": "存储治理：隐私清除需二次确认",
      "purpose": "与数据生命周期联动，确认 purge API 拒绝无 confirm 的请求，防止误删 trace/tools 审计记录。",
      "method": "POST",
      "path": "/api/context/sessions/00000000-0000-0000-0000-000000000000/purge",
      "input": { "confirm": false },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error", "hint"]
      }
    },
    {
      "id": "m10-trace-rotate",
      "title": "手动轮转 trace active 段",
      "purpose": "确认可将当前 trace-current.jsonl 封存到 segments，避免单文件无限增长。",
      "method": "POST",
      "path": "/api/trace/rotate",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["rotated", "activeFile"]
      }
    },
    {
      "id": "m10-storage-cleanup-runs",
      "title": "查询清理批次历史",
      "purpose": "确认已执行的清理批次（apply 后写入 cleanup-runs.jsonl）可被读回，提供「实际删了什么」的审计入口。",
      "method": "GET",
      "path": "/api/storage/cleanup/runs",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["runs"]
      }
    },
    {
      "id": "m10-storage-cleanup-preview-all",
      "title": "全量清理预览含 DB 与 trace 候选",
      "purpose": "确认 scope=all 时 preview 可返回 delete_db_rows / rewrite_file 等扩展动作类型，且 summary 含 candidateDbRows。",
      "method": "POST",
      "path": "/api/storage/cleanup/preview",
      "input": {
        "scope": "all"
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["cleanupRunId", "summary", "actions"],
        "bodyPaths": {
          "summary.candidateDbRows": "number"
        }
      }
    },
    {
      "id": "m10-storage-cleanup-runs-limit",
      "title": "清理批次历史支持 limit 参数",
      "purpose": "确认 limit 查询参数被解析且上限受控（最多 200），避免一次性读回过多历史记录。",
      "method": "GET",
      "path": "/api/storage/cleanup/runs?limit=5",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["runs"]
      }
    },
    {
      "id": "m10-storage-trace-quota-preview",
      "title": "全量预览触发 traceRawBytes 配额动作",
      "purpose": "确认 trace 段超出 traceRawBytes 时，preview(all) 返回 trace delete_file 候选动作（按最旧段优先）。",
      "method": "POST",
      "path": "/api/storage/cleanup/preview",
      "input": {
        "scope": "all",
        "include": ["trace"]
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["cleanupRunId", "actions"]
      }
    },
    {
      "id": "m10-storage-trace-quota-apply",
      "title": "trace 配额动作可执行并落审计",
      "purpose": "确认配额触发的 trace delete_file 动作可被 apply 执行，且写入 cleanup-runs 审计记录。",
      "method": "POST",
      "path": "/api/storage/cleanup/apply",
      "input": {
        "cleanupRunId": "来自上一条 preview",
        "confirm": true
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["applied", "actions", "bytesFreed"]
      }
    }
  ]
}
