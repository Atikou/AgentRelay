{
  "featureId": "m9-orchestrator",
  "title": "编排与 Run",
  "cases": [
    {
      "id": "m9-runs-list",
      "title": "列出最近 Run",
      "purpose": "确认 Orchestrator 写入的 runs 表可通过 GET /api/runs 查询。",
      "method": "GET",
      "path": "/api/runs?limit=10",
      "input": {},
      "expect": {
        "status": 200,
        "bodyHasKeys": ["runs"],
        "bodyPaths": { "runs": "array" }
      }
    },
    {
      "id": "m9-config-orchestrator-cap",
      "title": "配置含编排能力标记",
      "purpose": "确认 capabilities 暴露 orchestrator 与 runsApi，便于测试台探测编排层是否启用。",
      "method": "GET",
      "path": "/api/config",
      "input": {},
      "expect": {
        "status": 200,
        "bodyPaths": {
          "capabilities.orchestrator": "boolean",
          "capabilities.runsApi": "boolean"
        }
      }
    },
    {
      "id": "m9-api-spec",
      "title": "API 规范可访问",
      "purpose": "确认 public/api-spec.json 经静态服务暴露，供 /api-docs 交互参考页加载。",
      "method": "GET",
      "path": "/api-spec.json",
      "input": {},
      "expect": {
        "status": 200,
        "bodyPaths": { "info.title": "string", "paths": "object" },
        "bodyHasKeys": ["openapi", "info", "paths", "components", "tags"]
      }
    },
    {
      "id": "m9-api-docs-html",
      "title": "API 参考页可访问",
      "purpose": "确认 GET /api-docs 返回交互参考 HTML，且引用本地 api-spec 与 Scalar 资源。",
      "method": "GET",
      "path": "/api-docs",
      "input": {},
      "expect": {
        "status": 200,
        "contentTypeIncludes": "text/html",
        "bodyIncludes": ["/api-spec.json", "AgentRelay", "data-url"]
      }
    },
    {
      "id": "m9-run-report-missing",
      "title": "不存在的 Run 报告返回 404",
      "purpose": "确认 GET /api/runs/:id/report 在 Run 不存在时返回明确错误。",
      "method": "GET",
      "path": "/api/runs/00000000-0000-0000-0000-000000000000/report",
      "input": {},
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m9-run-report-timeline-capability",
      "title": "配置暴露运行报告时间线能力",
      "purpose": "确认服务端声明 GET /api/runs/:id/report 会返回按类别排序的 timeline 字段，供测试台时间线面板使用。",
      "method": "GET",
      "path": "/api/config",
      "input": {},
      "expect": {
        "status": 200,
        "bodyPaths": {
          "capabilities.runReportTimeline": true,
          "capabilities.runReportExport": true
        }
      }
    },
    {
      "id": "m9-run-report-timeline-contract",
      "title": "运行报告响应含 timeline 数组",
      "purpose": "确认 report 对象在存在 trace 时包含 timeline 数组（结构与 runReport.ts 一致）；无 trace 时仍返回 404。",
      "method": "GET",
      "path": "/api/runs?limit=1",
      "input": {},
      "expect": {
        "status": 200,
        "bodyHasKeys": ["runs"],
        "bodyPaths": {
          "runs": "array"
        }
      }
    },
    {
      "id": "m9-agent-resume-empty-runid",
      "title": "agent/resume 空 runId 返回 400",
      "purpose": "回归：续跑接口校验 runId，避免无状态恢复请求进入 Orchestrator。",
      "method": "POST",
      "path": "/api/agent/resume",
      "input": { "runId": "" },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m9-agent-resume-missing-run",
      "title": "agent/resume 不存在 run 返回 404",
      "purpose": "回归：对已删除或从未创建的 runId 续跑应明确 404，与取消后不可续跑语义一致。",
      "method": "POST",
      "path": "/api/agent/resume",
      "input": { "runId": "00000000-0000-0000-0000-000000000000" },
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error", "runId"]
      }
    },
    {
      "id": "m9-config-p3-capabilities",
      "title": "配置暴露 P3 修复能力标记",
      "purpose": "确认 startupRecovery、runReportExport、modelTokenStreaming、routerEvaluatorV3、answerEvaluatorV4、costBudgetPerRun 等能力可探测。",
      "method": "GET",
      "path": "/api/config",
      "input": {},
      "expect": {
        "status": 200,
        "bodyPaths": {
          "capabilities.startupRecovery": true,
          "capabilities.runReportExport": true,
          "capabilities.runReportTimeline": true,
          "capabilities.modelTokenStreaming": true,
          "capabilities.routerEvaluatorV3": true,
          "capabilities.answerEvaluatorV4": true,
          "capabilities.costBudgetPerRun": true
        }
      }
    },
    {
      "id": "m9-run-delete-missing",
      "title": "删除不存在的 Run 返回 404",
      "purpose": "确认 DELETE /api/runs/:id 在 Run 不存在时拒绝删除，避免误操作。",
      "method": "DELETE",
      "path": "/api/runs/00000000-0000-0000-0000-000000000099",
      "input": null,
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error"]
      }
    }
  ]
}
