{
  "milestone": "M7",
  "feature": "安全与审计",
  "featureId": "m7-security",
  "summary": "验证 trace 导出 API、脱敏后的审计事件结构、shell 命令安全策略与远程模型调用前脱敏能力。",
  "cases": [
    {
      "id": "m7-sensitive-detection-capability",
      "title": "配置暴露敏感信息检测能力",
      "purpose": "确认服务端声明已启用敏感信息检测，前端和外部调用方可据此展示隐私保护状态。",
      "method": "GET",
      "path": "/api/config",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["capabilities"],
        "bodyPaths": {
          "capabilities.sensitiveDetection": true
        }
      }
    },
    {
      "id": "m7-model-prompt-redaction-capability",
