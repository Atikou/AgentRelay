    {
      "id": "m7-shell-danger-blocked",
      "title": "危险 shell 未确认时返回风险预览",
      "purpose": "回归 M7 确认门：rm -rf 未确认时不得执行，只返回 needsConfirmation 与 dangerous 风险预览。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": {
        "name": "shell_run",
        "input": { "command": "rm -rf /" }
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["needsConfirmation", "preview"],
        "bodyPaths": {
          "needsConfirmation": true,
          "preview.kind": "shell_run",
          "preview.risk.level": "dangerous",
          "risk.tier": "critical",
          "risk.commandLevel": "dangerous"
        }
      }
    },
    {
      "id": "m7-shell-danger-confirm-blocked",
      "title": "危险 shell 确认后仍被策略拒绝",
      "purpose": "确认用户显式 confirm 后，高风险命令仍会被 ShellPolicy 拒绝，不会因为确认而执行 dangerous 操作。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": {
        "name": "shell_run",
        "input": { "command": "rm -rf /" },
        "confirm": true
      },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["ok", "category"],
        "bodyPaths": {
          "ok": false,
          "category": "permission_error",
          "risk.tier": "critical",
          "risk.policyBlocked": true
        }
      }
    },
    {
      "id": "m7-shell-safe-command",
      "title": "安全 shell 命令可执行",
      "purpose": "确认未命中风险规则、allow/deny 策略允许的命令可通过 shell_run 执行，并返回 exitCode。",
      "method": "POST",
      "path": "/api/tools/run",
      "input": {
        "name": "shell_run",
        "input": { "command": "node -e \"console.log(42)\"" },
        "confirm": true
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["ok", "output"],
        "bodyPaths": {
          "ok": true,
          "output.exitCode": 0
        }
      }
    },
