{
  "milestone": "M1",
  "feature": "智能体对话循环",
  "featureId": "m1-agent",
  "summary": "验证 AgentLoop 入口 /api/agent 的参数校验（不依赖在线模型即可测的部分）。",
  "cases": [
    {
      "id": "m1-agent-empty",
      "title": "空 message 返回 400",
      "purpose": "确认智能体接口拒绝空用户消息，避免无意义模型调用与空循环。",
      "method": "POST",
      "path": "/api/agent",
      "input": { "message": "" },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m1-agent-unknown-client",
      "title": "未知模型客户端返回 404",
      "purpose": "确认智能体接口在指定不存在的 clientName 时立即拒绝，避免进入路由或模型调用。",
      "method": "POST",
      "path": "/api/agent",
      "input": { "message": "ping", "clientName": "missing-client" },
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m1-agent-stream-empty",
      "title": "流式接口空 message 返回 400",
      "purpose": "确认 /api/agent/stream 在开启 SSE 前完成与 /api/agent 相同的 message 校验。",
      "method": "POST",
      "path": "/api/agent/stream",
      "input": { "message": "" },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m1-agent-stream-unknown-client",
      "title": "流式接口未知 client 返回 404",
      "purpose": "确认流式入口在 clientName 无效时仍返回 JSON 404，不进入 event-stream。",
      "method": "POST",
      "path": "/api/agent/stream",
      "input": { "message": "ping", "clientName": "missing-client" },
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error"]
      }
    }
  ]
}
