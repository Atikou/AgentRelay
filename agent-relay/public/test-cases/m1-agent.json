{
  "milestone": "M1",
  "feature": "智能体对话循环",
  "featureId": "m1-agent",
  "summary": "验证 AgentLoop 入口 /api/agent 的参数校验、计划/实现模式 WorkflowPlanner 预扫描与分项预算。",
  "cases": [
    {
      "id": "m1-agent-empty",
      "title": "空 message 返回 400",
      "purpose": "确认智能体接口拒绝空用户消息，避免无意义模型调用与空循环。",
      "method": "POST",
      "path": "/api/agent",
      "input": { "message": "" },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m1-agent-unknown-client",
      "title": "未知模型客户端返回 404",
      "purpose": "确认智能体接口在指定不存在的 clientName 时立即拒绝，避免进入路由或模型调用。",
      "method": "POST",
      "path": "/api/agent",
      "input": { "message": "ping", "clientName": "missing-client" },
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m1-agent-stream-empty",
      "title": "流式接口空 message 返回 400",
      "purpose": "确认 /api/agent/stream 在开启 SSE 前完成与 /api/agent 相同的 message 校验。",
      "method": "POST",
      "path": "/api/agent/stream",
      "input": { "message": "" },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m1-agent-stream-unknown-client",
      "title": "流式接口未知 client 返回 404",
      "purpose": "确认流式入口在 clientName 无效时仍返回 JSON 404，不进入 event-stream。",
      "method": "POST",
      "path": "/api/agent/stream",
      "input": { "message": "ping", "clientName": "missing-client" },
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m1-agent-plan-low-budget-meta",
      "title": "计划模式低预算返回 executionMeta",
      "purpose": "确认计划模式即使预算很低，也会返回停止原因、是否需要更多预算和建议迭代数，便于排查不是空白失败。",
      "method": "POST",
      "path": "/api/agent",
      "input": {
        "message": "请进入计划模式，只读列出当前项目可以继续完善的方向。",
        "mode": "plan",
        "budget": {
          "maxModelTurns": 1,
          "maxToolCalls": 2,
          "maxReadCalls": 2,
          "maxWriteCalls": 0,
          "maxShellCalls": 0,
          "maxRuntimeMs": 60000
        },
        "persist": false
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["answer", "steps", "executionMeta"],
        "bodyPaths": {
          "executionMeta.mode": "plan",
          "executionMeta.budget.maxModelTurns": 1,
          "executionMeta.stopReason": "string",
          "executionMeta.usedModelTurns": "number"
        }
      }
    },
    {
      "id": "m1-agent-plan-default-budget",
      "title": "计划模式默认使用策略预算",
      "purpose": "确认未显式传 budget 时，计划模式不会沿用普通 chat 默认值，而是采用只读计划策略预算。",
      "method": "POST",
      "path": "/api/agent",
      "input": {
        "message": "请进入计划模式，只读分析当前项目结构，然后给出下一步计划。",
        "mode": "plan",
        "persist": false
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["answer", "executionMeta"],
        "bodyPaths": {
          "executionMeta.mode": "plan",
          "executionMeta.budget.maxModelTurns": 16,
          "executionMeta.budget.maxWriteCalls": 0,
          "executionMeta.budget.maxShellCalls": 0,
          "executionMeta.usedModelTurns": "number",
          "executionMeta.usedToolCalls": "number"
        }
      }
    },
    {
      "id": "m1-agent-plan-report-contract",
      "title": "计划报告走只读 Agent 链路",
      "purpose": "确认给用户看的 Markdown 计划报告应通过 /api/agent mode=plan 生成，而不是 /api/plan 的机器计划 JSON 入口。",
      "method": "POST",
      "path": "/api/agent",
      "input": {
        "message": "# 计划模式分析结果\n\n## 1. 目标理解\n\n请只读分析当前项目。",
        "mode": "plan",
        "persist": false
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["answer", "executionMeta"],
        "bodyPaths": {
          "executionMeta.mode": "plan",
          "executionMeta.usedWriteCalls": 0,
          "executionMeta.usedShellCalls": 0
        }
      }
    },
    {
      "id": "m1-agent-plan-workflow-prescan",
      "title": "计划模式项目分析先预扫描",
      "purpose": "确认计划模式遇到当前项目分析任务时，会在模型首轮前执行只读内部预扫描，并把定位统计写入 executionMeta.location。",
      "method": "POST",
      "path": "/api/agent",
      "input": {
        "message": "请进入计划模式，只读分析当前项目架构并列出下一步完善计划。",
        "mode": "plan",
        "persist": false
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["answer", "steps", "executionMeta"],
        "bodyPaths": {
          "executionMeta.mode": "plan",
          "executionMeta.location.usedLocateSteps": "number",
          "executionMeta.location.needsContinue": "boolean",
          "executionMeta.usedWriteCalls": 0,
          "executionMeta.usedShellCalls": 0
        }
      }
    },
    {
      "id": "m1-agent-implement-workflow-locate",
      "title": "实现模式代码任务先预定位",
      "purpose": "确认 WorkflowPlanner 为 implement 模式代码变更选择 locate+context_pack 预扫描，并写入 executionMeta.location。",
      "method": "POST",
      "path": "/api/agent",
      "input": {
        "message": "实现模式：修改 AgentLoop 中的预算耗尽收尾逻辑，先定位相关文件。",
        "mode": "implement",
        "persist": false,
        "budget": { "maxModelTurns": 2, "maxToolCalls": 6, "maxReadCalls": 6, "maxWriteCalls": 2, "maxShellCalls": 0, "maxRuntimeMs": 120000 }
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["answer", "steps", "executionMeta"],
        "bodyPaths": {
          "executionMeta.mode": "implement",
          "executionMeta.location.usedLocateSteps": "number",
          "executionMeta.usedReadCalls": "number"
        }
      }
    },
    {
      "id": "m1-agent-plan-workflow-readonly-command-text",
      "title": "只读禁改提示不屏蔽预扫描",
      "purpose": "确认用户要求不要执行会改变项目状态的命令时，系统仍允许 project_scan 等只读预扫描，避免计划模式反复探索耗尽预算。",
      "method": "POST",
      "path": "/api/agent",
      "input": {
        "message": "请进入计划模式，不要执行会改变项目状态的命令，只读分析当前项目还有哪些未实现功能。",
        "mode": "plan",
        "persist": false
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["answer", "steps", "executionMeta"],
        "bodyPaths": {
          "executionMeta.mode": "plan",
          "executionMeta.location.usedLocateSteps": "number",
          "executionMeta.usedWriteCalls": 0,
          "executionMeta.usedShellCalls": 0
        }
      }
    },
    {
      "id": "m1-agent-budget-suggested-action",
      "title": "预算耗尽且定位不足返回 suggestedAction",
      "purpose": "确认 executionMeta 在 needsMoreBudget 且定位未完成时返回结构化 continue_locating，便于续跑。",
      "method": "POST",
      "path": "/api/agent",
      "input": {
        "message": "请进入计划模式，只读分析当前项目所有模块与路由实现。",
        "mode": "plan",
        "budget": {
          "maxModelTurns": 1,
          "maxToolCalls": 2,
          "maxReadCalls": 1,
          "maxWriteCalls": 0,
          "maxShellCalls": 0,
          "maxRuntimeMs": 60000
        },
        "persist": false
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["answer", "executionMeta"],
        "bodyPaths": {
          "executionMeta.stopReason": "budget_exhausted",
          "executionMeta.needsMoreBudget": true,
          "executionMeta.suggestedAction": "continue_locating"
        }
      }
    },
    {
      "id": "m1-agent-location-exploration-meta",
      "title": "executionMeta.location 含 exploration 统计",
      "purpose": "确认内部预扫描后 executionMeta.location 聚合 exploration 重复/增益统计。",
      "method": "POST",
      "path": "/api/agent",
      "input": {
        "message": "请进入计划模式，只读分析当前项目架构。",
        "mode": "plan",
        "persist": false
      },
      "expect": {
        "status": 200,
        "bodyPaths": {
          "executionMeta.location.exploration.duplicateCount": "number",
          "executionMeta.location.exploration.informationGain": "number"
        }
      }
    },
    {
      "id": "m1-agent-invalid-mode",
      "title": "非法 mode 返回 400",
      "purpose": "确认运行模式拼写错误时直接返回参数错误，避免被静默当成普通智能体请求执行。",
      "method": "POST",
      "path": "/api/agent",
      "input": {
        "message": "hello",
        "mode": "invalid",
        "persist": false
      },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m1-agent-config-smart-routing",
      "title": "GET /api/config 暴露 agentSmartRouting",
      "purpose": "确认默认 /api/agent 已接入 SmartModelRouter + ModelRegistry，不再仅依赖旧 ModelRouter.taskType。",
      "method": "GET",
      "path": "/api/config",
      "input": {},
      "expect": {
        "status": 200,
        "bodyPaths": {
          "capabilities.agentSmartRouting": true
        }
      }
    },
    {
      "id": "m1-agent-resume-missing-runid",
      "title": "续跑缺少 runId 返回 400",
      "purpose": "确认 /api/agent/resume 在缺少 runId 时立即拒绝，避免误创建新 Run。",
      "method": "POST",
      "path": "/api/agent/resume",
      "input": {},
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m1-agent-resume-unknown-run",
      "title": "续跑未知 runId 返回 400",
      "purpose": "确认无 resumable 状态的 runId 不能续跑，返回明确错误而非进入 AgentLoop。",
      "method": "POST",
      "path": "/api/agent/resume",
      "input": { "runId": "00000000-0000-4000-8000-000000000000" },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m1-agent-config-run-state-store",
      "title": "GET /api/config 暴露 runStateStore",
      "purpose": "确认 capabilities 声明 RunStateStore 已落地，便于测试台与客户端探测续跑能力。",
      "method": "GET",
      "path": "/api/config",
      "input": {},
      "expect": {
        "status": 200,
        "bodyPaths": {
          "capabilities.runStateStore": true
        }
      }
    },
    {
      "id": "m1-agent-runstate-location-doc",
      "title": "api-spec RunState 含 location 定位上下文",
      "purpose": "确认 OpenAPI RunState schema 已声明 location（searchPlan/visitedFiles/candidateFiles），便于客户端续跑时恢复定位状态。",
      "method": "GET",
      "path": "/api-docs",
      "input": {},
      "expect": {
        "status": 200,
        "bodyContains": ["location", "visitedFiles", "searchPlan", "indexFileCount"]
      }
    },
    {
      "id": "m1-agent-plan-low-budget-runstate-pending",
      "title": "计划模式低预算耗尽返回 runState.pendingSteps",
      "purpose": "验证预算耗尽时 runState 含 pendingSteps，续跑可继续内部预扫描；location 在 locate 执行后写入。",
      "method": "POST",
      "path": "/api/agent",
      "input": {
        "message": "请进入计划模式，只读分析当前项目模型路由模块并生成升级计划",
        "mode": "plan",
        "budget": {
          "maxModelTurns": 2,
          "maxToolCalls": 3,
          "maxReadCalls": 1,
          "maxWriteCalls": 0,
          "maxShellCalls": 0,
          "maxRuntimeMs": 120000
        }
      },
      "expect": {
        "status": 200,
        "bodyPaths": {
          "reachedLimit": true,
          "runState.status": "resumable",
          "runState.pendingSteps": "array"
        }
      }
    },
    {
      "id": "m1-agent-run-policy-manager-capability",
      "title": "GET /api/config 暴露 runPolicyManager",
      "purpose": "确认 capabilities 声明 RunPolicyManager 已落地，客户端可探测模式/预算策略解析能力。",
      "method": "GET",
      "path": "/api/config",
      "input": {},
      "expect": {
        "status": 200,
        "bodyPaths": {
          "capabilities.runPolicyManager": true
        }
      }
    },
    {
      "id": "m1-agent-budget-manager-capability",
      "title": "GET /api/config 暴露 budgetManager",
      "purpose": "确认 capabilities 声明 BudgetManager 已落地，客户端可探测分项预算管理能力。",
      "method": "GET",
      "path": "/api/config",
      "input": {},
      "expect": {
        "status": 200,
        "bodyPaths": {
          "capabilities.budgetManager": true
        }
      }
    },
    {
      "id": "m1-agent-finalizer-capability",
      "title": "GET /api/config 暴露 finalizer",
      "purpose": "确认 capabilities 声明 Finalizer 已落地，客户端可探测预算耗尽部分收尾与复杂度估算能力。",
      "method": "GET",
      "path": "/api/config",
      "input": {},
      "expect": {
        "status": 200,
        "bodyPaths": {
          "capabilities.finalizer": true
        }
      }
    },
    {
      "id": "m1-agent-budget-exhausted-suggested-tool-calls",
      "title": "预算耗尽时 executionMeta 含 suggestedToolCalls",
      "purpose": "验证 AgentLoop 经 Finalizer 在预算耗尽时返回复杂度估算与 completedSteps/missingSteps。",
      "method": "POST",
      "path": "/api/agent",
      "input": {
        "message": "一直列目录",
        "budget": {
          "maxModelTurns": 2,
          "maxToolCalls": 2,
          "maxReadCalls": 2,
          "maxWriteCalls": 0,
          "maxShellCalls": 0,
          "maxRuntimeMs": 60000
        }
      },
      "expect": {
        "status": 200,
        "bodyPaths": {
          "reachedLimit": true,
          "executionMeta.needsMoreBudget": true,
          "executionMeta.suggestedToolCalls": ">0",
          "executionMeta.missingSteps": "array"
        }
      }
    },
    {
      "id": "m1-agent-tool-result-layers-capability",
      "title": "GET /api/config 暴露 toolResultLayers",
      "purpose": "确认 capabilities 声明工具结果三层 trace 已落地，便于客户端区分 raw/model/user 展示。",
      "method": "GET",
      "path": "/api/config",
      "input": {},
      "expect": {
        "status": 200,
        "bodyPaths": {
          "capabilities.toolResultLayers": true
        }
      }
    },
    {
      "id": "m1-agent-auto-intent-verify-meta",
      "title": "自动意图识别返回 verify 元信息",
      "purpose": "确认统一 Agent 入口在用户要求运行测试/验证时，会在 executionMeta 中返回内部 intent=verify 与 verifyWorkflow，便于后续自动工作流路由。",
      "method": "POST",
      "path": "/api/agent",
      "input": {
        "message": "运行测试看看当前修改是否通过",
        "persist": false,
        "budget": {
          "maxModelTurns": 1,
          "maxToolCalls": 0,
          "maxReadCalls": 0,
          "maxWriteCalls": 0,
          "maxShellCalls": 0,
          "maxRuntimeMs": 60000
        }
      },
      "expect": {
        "status": 200,
        "bodyPaths": {
          "executionMeta.modeSource": "inferred",
          "executionMeta.intent": "verify",
          "executionMeta.workflowType": "verifyWorkflow"
        }
      }
    },
    {
      "id": "m1-agent-explicit-mode-overrides-intent",
      "title": "显式 mode 覆盖自动意图",
      "purpose": "确认用户显式传入 mode=plan 时，即使消息包含修改动作，系统也按只读 plan/planWorkflow 边界返回，避免自动路由越过用户指定模式。",
      "method": "POST",
      "path": "/api/agent",
      "input": {
        "message": "修改这个模块但先只给计划",
        "mode": "plan",
        "persist": false,
        "budget": {
          "maxModelTurns": 1,
          "maxToolCalls": 1,
          "maxReadCalls": 1,
          "maxWriteCalls": 0,
          "maxShellCalls": 0,
          "maxRuntimeMs": 60000
        }
      },
      "expect": {
        "status": 200,
        "bodyPaths": {
          "executionMeta.mode": "plan",
          "executionMeta.modeSource": "explicit",
          "executionMeta.intent": "plan",
          "executionMeta.workflowType": "planWorkflow",
          "executionMeta.usedWriteCalls": 0,
          "executionMeta.usedShellCalls": 0
        }
      }
    },
    {
      "id": "m1-agent-explicit-permission-policy-meta",
