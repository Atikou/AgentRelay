{
  "milestone": "M6",
  "feature": "上下文压缩与持久化",
  "featureId": "m6-context",
  "summary": "验证 ContextManager：会话、记忆、恢复 ContextPackage 与检索边界。",
  "cases": [
    {
      "id": "m6-sessions-list",
      "title": "会话列表为数组",
      "purpose": "确认 GET /api/context/sessions 返回 sessions 数组，用于测试台展示持久化会话。",
      "method": "GET",
      "path": "/api/context/sessions",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["sessions"],
        "bodyPaths": { "sessions": "array" }
      }
    },
    {
      "id": "m6-session-create",
      "title": "创建持久化会话",
      "purpose": "验证 POST /api/context/sessions 返回带 id 的 session 记录，作为后续恢复与压缩的载体。",
      "method": "POST",
      "path": "/api/context/sessions",
      "input": { "title": "测试会话 M6" },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["session"],
        "bodyPaths": {
          "session.id": "string",
          "session.title": "测试会话 M6"
        }
      }
    },
    {
      "id": "m6-session-rename-empty",
      "title": "PATCH 空标题返回 400",
      "purpose": "确认修改会话标题时拒绝空字符串，避免侧栏出现无标题会话。",
      "method": "PATCH",
      "path": "/api/context/sessions/00000000-0000-0000-0000-000000000000",
      "input": { "title": "" },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m6-session-delete-missing",
      "title": "DELETE 不存在的会话返回 404",
      "purpose": "确认删除会话接口对无效 sessionId 返回明确 404，避免误认删除成功。",
      "method": "DELETE",
      "path": "/api/context/sessions/00000000-0000-0000-0000-000000000000",
      "input": null,
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error", "sessionId"]
      }
    },
    {
      "id": "m6-session-purge-no-confirm",
      "title": "隐私清除未确认返回 400",
      "purpose": "确认 POST purge 必须携带 confirm: true，避免误触不可恢复的隐私清除。",
      "method": "POST",
      "path": "/api/context/sessions/00000000-0000-0000-0000-000000000000/purge",
      "input": {},
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m6-session-purge-missing",
      "title": "隐私清除不存在的会话返回 404",
      "purpose": "确认对已删除或不存在的 sessionId 执行 purge 时返回明确 404。",
      "method": "POST",
      "path": "/api/context/sessions/00000000-0000-0000-0000-000000000000/purge",
      "input": { "confirm": true },
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error", "sessionId"]
      }
    },
    {
      "id": "m6-session-create-with-workspace",
      "title": "创建会话并绑定工作区",
      "purpose": "验证 POST /api/context/sessions 接受 workspaceKey，会话级工具沙箱可与会话绑定。",
      "method": "POST",
      "path": "/api/context/sessions",
      "input": { "title": "工作区测试会话", "workspaceKey": "repo" },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["session"],
        "bodyPaths": {
          "session.id": "string",
          "session.workspaceKey": "repo"
        }
      }
    },
    {
      "id": "m6-session-create-invalid-workspace",
      "title": "无效 workspaceKey 返回 400",
      "purpose": "边界用例：配置外的工作区 id 应被拒绝，避免工具沙箱指向未知目录。",
      "method": "POST",
      "path": "/api/context/sessions",
      "input": { "title": "坏工作区", "workspaceKey": "not-a-workspace" },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m6-session-create-with-custom-workspace-root",
      "title": "创建会话并绑定自定义目录",
      "purpose": "验证 POST /api/context/sessions 接受 workspaceRoot，允许手动输入任意本机目录作为会话工作区。",
      "method": "POST",
      "path": "/api/context/sessions",
      "input": { "title": "自定义目录会话", "workspaceRoot": "D:\\Learn\\AgentTest\\agent-relay" },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["session"],
        "bodyPaths": {
          "session.id": "string",
          "session.workspaceKey": "string"
        }
      }
    },
    {
      "id": "m6-session-create-with-missing-workspace-root",
      "title": "不存在的 workspaceRoot 返回 400",
      "purpose": "边界用例：workspaceRoot 必须是存在的目录，避免会话绑定到无效路径。",
      "method": "POST",
      "path": "/api/context/sessions",
      "input": { "title": "坏路径", "workspaceRoot": "D:\\Path\\NotExist\\Never" },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m6-memory-create",
      "title": "写入全局偏好记忆",
      "purpose": "验证 POST /api/context/memories 能持久化结构化记忆并同步 FTS/向量索引。",
      "method": "POST",
      "path": "/api/context/memories",
      "input": {
        "scope": "global",
        "memoryType": "preference",
        "key": "test_lang",
        "value": "偏好使用 TypeScript 开发 AgentRelay",
        "summary": "TS 偏好",
        "importance": 0.8
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["memory"],
        "bodyPaths": {
          "memory.scope": "global",
          "memory.memoryType": "preference"
        }
      }
    },
    {
      "id": "m6-memory-upsert-same-key",
      "title": "重复 key 更新偏好记忆",
      "purpose": "确认同一 scope/memoryType/key 的长期记忆会更新原记录，避免测试台反复运行后在恢复上下文里出现重复偏好。",
      "method": "POST",
      "path": "/api/context/memories",
      "input": {
        "scope": "global",
        "memoryType": "preference",
        "key": "test_lang",
        "value": "偏好使用 TypeScript 开发 AgentRelay",
        "summary": "TS 偏好更新",
        "importance": 0.9
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["memory"],
        "bodyPaths": {
          "memory.key": "test_lang",
          "memory.summary": "TS 偏好更新"
        }
      }
    },
    {
      "id": "m6-memory-upsert-same-value",
      "title": "无 key 同内容记忆去重",
      "purpose": "覆盖测试台手动写入场景：没有显式 key 时，同 scope/memoryType/value 的偏好不应重复堆叠。",
      "method": "POST",
      "path": "/api/context/memories",
      "input": {
        "scope": "global",
        "memoryType": "preference",
        "value": "偏好使用 TypeScript 开发 AgentRelay",
        "summary": "TS 偏好",
        "importance": 0.8
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["memory"],
        "bodyPaths": {
          "memory.scope": "global",
          "memory.memoryType": "preference",
          "memory.value": "偏好使用 TypeScript 开发 AgentRelay"
        }
      }
    },
    {
      "id": "m6-search-missing-q",
      "title": "检索缺少 q 返回 400",
      "purpose": "边界用例：未提供查询词时应明确 4xx，避免空检索误用。",
      "method": "GET",
      "path": "/api/context/search",
      "input": null,
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m6-session-missing-detail",
      "title": "不存在的会话详情返回 404",
      "purpose": "验证会话恢复/详情接口对无效 sessionId 有明确 404，前端可据此重新创建会话。",
      "method": "GET",
      "path": "/api/context/sessions/not-exist",
      "input": null,
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m6-memory-missing-value",
      "title": "记忆缺少 value 返回 400",
      "purpose": "确认长期记忆写入必须包含有效内容，避免空记忆进入 SQLite/FTS/向量索引。",
      "method": "POST",
      "path": "/api/context/memories",
      "input": {
        "scope": "global",
        "memoryType": "preference",
        "value": ""
      },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m6-restore-missing-session",
      "title": "恢复不存在的会话返回 404",
      "purpose": "边界用例：无效 sessionId 恢复时应 404，避免前端误用已删除会话。",
      "method": "GET",
      "path": "/api/context/sessions/not-exist-session/restore",
      "input": null,
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m6-memory-deactivate-missing",
      "title": "停用不存在的记忆返回 404",
      "purpose": "边界用例：对无效 memoryId 调用 deactivate 应明确 404，避免误操作。",
      "method": "POST",
      "path": "/api/context/memories/not-exist-memory/deactivate",
      "input": { "reason": "test" },
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m6-memory-deactivate",
      "title": "停用已写入的记忆",
      "purpose": "先运行「写入全局偏好记忆」复制 memory.id，将路径改为 /api/context/memories/{id}/deactivate 后执行；验证记忆被停用且不再出现在 GET /api/context/memories。",
      "method": "POST",
      "path": "/api/context/memories/PASTE_MEMORY_ID/deactivate",
      "input": { "reason": "test-bench" },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["memoryId", "deactivated"],
        "bodyPaths": {
          "deactivated": true
        }
      }
    },
    {
      "id": "m6-dry-run-persists-plan-steps",
      "title": "任务 dry-run 持久化计划步骤",
      "purpose": "验证 POST /api/task/dry-run 将 plan.steps 写入 task_steps，供后续 current_plan 上下文注入。需先创建会话并将 sessionId 填入 input。",
      "method": "POST",
      "path": "/api/task/dry-run",
      "input": {
        "sessionId": "PASTE_SESSION_ID",
        "plan": {
          "goal": "M6 计划注入测试",
          "steps": [
            {
              "id": "step-read",
              "title": "读取 README",
              "description": "只读",
              "status": "pending",
              "requiredPermissions": ["read"],
              "needsConfirmation": false
            }
          ]
        }
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["runId", "taskId", "plan"]
      }
    },
    {
      "id": "m6-restore-includes-current-plan",
      "title": "恢复上下文含 current_plan 节",
      "purpose": "在 dry-run 写入计划后，GET restore 的 contextPackage.systemSections 应含 type=current_plan（与「创建会话」+ dry-run 链式执行）。",
      "method": "GET",
      "path": "/api/context/sessions/PASTE_SESSION_ID/restore?q=继续",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["contextPackage"]
      }
    },
    {
      "id": "m6-file-snippets-read-file",
      "title": "read_file 工具消息注入 file_snippets",
      "purpose": "经 Agent 或测试写入 read_file 结果后，GET restore 的 systemSections 应含 type=file_snippets 且文本含文件路径（链式：先创建会话再跑只读 Agent）。",
      "method": "GET",
      "path": "/api/context/sessions/PASTE_SESSION_ID/restore?q=继续",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["contextPackage"]
      }
    },
    {
      "id": "m6-file-snippets-search-text",
      "title": "search_text 命中注入片段",
      "purpose": "search_text 工具 JSON 含 results[].path 时，file_snippets 应展示路径与行预览；用于验证多工具解析而非仅 read_file。",
      "method": "GET",
      "path": "/api/context/sessions/PASTE_SESSION_ID/restore",
      "input": null,
      "expect": {
        "status": 200,
        "bodyPaths": { "contextPackage.systemSections": "array" }
      }
    },
    {
      "id": "m6-restore-includes-tagged-fragments",
      "title": "恢复上下文含 taggedFragments",
      "purpose": "验证 GET restore 返回的 contextPackage.taggedFragments 为带 tags 的扁平片段数组，便于按标签重组上下文。",
      "method": "GET",
      "path": "/api/context/sessions/PASTE_SESSION_ID/restore?q=继续",
      "input": null,
      "expect": {
        "status": 200,
        "bodyPaths": {
          "contextPackage.taggedFragments": "array"
        }
      }
    },
    {
      "id": "m6-search-by-tags",
      "title": "记忆检索支持 tags 过滤",
      "purpose": "验证 GET /api/context/search 的 tags 参数可按 memory:preference 等标签过滤检索结果。",
      "method": "GET",
      "path": "/api/context/search?q=TypeScript&tags=memory:preference",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["hits"],
        "bodyPaths": { "hits": "array" }
      }
    },
    {
      "id": "m6-restore-tool-role-sanitized-pre-call",
      "title": "历史工具消息不会作为原生 tool 发送",
      "purpose": "先通过 Agent 工具调用或已有历史会话写入 tool 消息，再恢复上下文；renderedPrompt.finalMessages 应只把历史工具结果作为普通用户侧历史文本，避免 OpenAI-compatible 模型因缺少 tool_calls 返回 400。",
      "method": "GET",
      "path": "/api/context/sessions/PASTE_SESSION_ID/restore?q=继续历史会话&phase=pre_call",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["contextPackage", "renderedPrompt"],
        "bodyPaths": {
          "contextPackage.messages": "array",
          "renderedPrompt.finalMessages": "array"
        }
      }
    },
    {
      "id": "m6-restore-tool-role-sanitized-post-call",
      "title": "调试快照保留原始工具记录但隔离模型输入",
      "purpose": "对同一历史会话查看 post_call 调试快照，确认 contextPackage 仍可用于工具摘要/审计，而 renderedPrompt 是调试用渲染结果，不应被视为可持久化的原生 tool_calls 链。",
      "method": "GET",
      "path": "/api/context/sessions/PASTE_SESSION_ID/restore?phase=post_call",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["phase", "contextPackage", "renderedPrompt"],
        "bodyPaths": {
          "phase": "post_call",
          "contextPackage.systemSections": "array",
          "renderedPrompt.finalMessages": "array"
        }
      }
    },
    {
      "id": "m6-restore-context-package",
      "title": "恢复接口返回 contextPackage",
      "purpose": "先运行「创建持久化会话」复制 session.id，将路径改为 /api/context/sessions/{id}/restore?q=测试 后执行；验证响应含结构化 contextPackage.systemSections。",
      "method": "GET",
      "path": "/api/context/sessions/PASTE_SESSION_ID/restore?q=测试",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["session", "phase", "contextPackage", "renderedPrompt"],
        "bodyPaths": {
          "phase": "pre_call",
          "contextPackage.sessionId": "string",
          "contextPackage.systemSections": "array",
          "contextPackage.messages": "array"
        }
      }
    },
    {
      "id": "m6-memory-unverified-completion-filter",
      "title": "未验证完成声明记忆不入检索",
      "purpose": "验证 MemoryRetriever 过滤「增强方案已完成」类未验证完成声明，防止工作区记忆长期污染 context_pack。",
      "method": "POST",
      "path": "/api/context/memories",
      "input": {
        "scope": "global",
        "memoryType": "fact",
        "value": "增强方案已完成，所有文件已写入",
        "summary": "虚假完成记忆",
        "importance": 0.9
      },
      "expect": {
        "status": 200,
        "bodyHasKeys": ["memory"]
      }
    },
    {
      "id": "m6-memory-search-no-false-completion",
      "title": "检索结果不含未验证完成声明",
      "purpose": "先运行「未验证完成声明记忆不入检索」写入虚假完成记忆，再执行本用例；期望 GET /api/context/search 的 hits 中不出现「增强方案已完成」（MemoryRetriever trustLevel 过滤）。",
      "method": "GET",
      "path": "/api/context/search?q=增强方案&scope=global",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["hits"],
        "bodyPaths": { "hits": "array" }
      }
    },
    {
      "id": "m6-context-trust-restore-structure",
      "title": "恢复接口支持 context_corrections 段",
      "purpose": "确认 GET restore 返回的 contextPackage.systemSections 为数组，去污后可在其中出现 type=context_corrections（虚假完成纠偏）；与 npm run test:context-trust 单元测试互补。",
      "method": "GET",
      "path": "/api/context/sessions/PASTE_SESSION_ID/restore?q=安装依赖",
      "input": null,
      "expect": {
        "status": 200,
        "bodyHasKeys": ["contextPackage", "renderedPrompt"],
        "bodyPaths": {
          "contextPackage.systemSections": "array",
          "contextPackage.messages": "array"
        }
      }
    }
  ]
}
