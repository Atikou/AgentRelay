{
  "featureId": "m1-auto-workflow-ui",
  "milestone": "M1",
  "title": "自动工作流测试台 UI",
  "description": "P4 统一自动入口、权限策略选择与工作流状态展示。",
  "cases": [
    {
      "id": "m1-auto-ui-permission-policy-select",
      "title": "测试台提供权限策略下拉",
      "purpose": "确认主输入区已用 permissionPolicy 下拉替代旧的对话/计划/智能体三分入口与 autoConfirm 勾选，覆盖只读到自动执行五档策略。",
      "method": "GET",
      "path": "/",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": [
          "permission-policy-select",
          "confirmBeforeEdit",
          "autoEdit",
          "confirmBeforeRun",
          "autoRun",
          "readOnly"
        ]
      }
    },
    {
      "id": "m1-auto-ui-unified-agent-handler",
      "title": "测试台统一走自动 Agent 入口",
      "purpose": "确认 app.js 默认通过 handleUnifiedAgent 调用 /api/agent 并传递 permissionPolicy，高级选项可覆盖显式 mode。",
      "method": "GET",
      "path": "/app.js",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": [
          "handleUnifiedAgent",
          "permissionPolicy",
          "/api/agent",
          "explicit-mode-select",
          "attachWorkflowBadgeToLastUserMessage"
        ]
      }
    },
    {
      "id": "m1-auto-ui-workflow-badge-style",
      "title": "用户消息旁工作流状态样式",
      "purpose": "确认样式表已登记 msg-workflow-badge，使用户消息在响应后可展示内部工作流/任务状态标签。",
      "method": "GET",
      "path": "/styles.css",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": [".msg-workflow-badge", ".workflow-status"]
      }
    },
    {
      "id": "m1-auto-ui-advanced-explicit-mode",
      "title": "高级选项保留显式 mode 覆盖",
      "purpose": "确认高级折叠区仍提供 chat/plan/implement/debug/review 显式模式，供测试与调试强制边界。",
      "method": "GET",
      "path": "/",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": [
          "explicit-mode-select",
          "高级选项",
          "强制计划",
          "强制实现",
          "自动推断（推荐）"
        ]
      }
    },
    {
      "id": "m1-auto-ui-structured-bubble-class",
      "title": "结构化面板消息添加紧凑样式钩子",
      "purpose": "确认 addMessage 在插入 DOM 面板时添加 structured-bubble，避免工具面板、审计回放、历史卡片继承纯文本 pre-wrap 间距。",
      "method": "GET",
      "path": "/app.js",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["structured-bubble", "content instanceof Node"]
      }
    },
    {
      "id": "m1-auto-ui-structured-bubble-spacing",
      "title": "结构化面板关闭 pre-wrap 空白渲染",
      "purpose": "确认 styles.css 将 structured-bubble 的 white-space 设为 normal，修复审计记录和其他面板条目间距过大的显示问题。",
      "method": "GET",
      "path": "/styles.css",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": [".bubble.structured-bubble", "white-space: normal"]
      }
    },
    {
      "id": "m1-auto-ui-advanced-panel-container",
      "title": "高级选项使用独立菜单容器",
      "purpose": "确认高级选项的显式模式与流式开关被包在 advanced-panel 内，避免多个字段共享绝对定位后互相重叠。",
      "method": "GET",
      "path": "/",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["advanced-panel", "explicit-mode-select", "stream-agent-input", "stream-tokens-input"]
      }
    },
    {
      "id": "m1-auto-ui-advanced-panel-spacing",
      "title": "高级选项菜单纵向紧凑排列",
      "purpose": "确认高级选项面板由 JS 锚定到按钮左上角，并由 CSS 变量承载位置，避免靠右时被裁切或靠左时伸入侧栏。",
      "method": "GET",
      "path": "/app.js",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["positionAdvancedPanel", "--advanced-panel-left", "summaryRect.top - panelRect.height - 8"]
      }
    },
    {
      "id": "m1-auto-ui-local-datetime-helper",
      "title": "app.js 提供本地时区时间格式化",
      "purpose": "确认测试台通过 parseTimestamp/formatDateTime 将服务端 ISO/Unix 时间转为浏览器当前系统时区显示。",
      "method": "GET",
      "path": "/app.js",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["parseTimestamp", "formatDateTime", "toLocaleString(\"zh-CN\""]
      }
    },
    {
      "id": "m1-auto-ui-notification-local-time",
      "title": "通知列表使用 formatDateTime",
      "purpose": "确认通知队列与调度待办不再直接展示 UTC ISO 字符串，而是经 formatDateTime 本地化。",
      "method": "GET",
      "path": "/app.js",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": ["formatDateTime(n.timestamp)", "formatDateTime(t.at)", "formatDateTime(t.lastFiredAt)"]
      }
    },
    {
      "id": "m1-auto-ui-history-markdown-final",
      "title": "历史会话渲染最终回答 Markdown",
      "purpose": "确认浏览历史会话时从 final action 提取 answer 并用 marked 渲染，而非逐条展示原始 JSON。",
      "method": "GET",
      "path": "/app.js",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": [
          "renderHistoryMessages",
          "extractFinalAnswerFromReplies",
          "renderMarkdownInto",
          "history-answer-bubble"
        ]
      }
    },
    {
      "id": "m1-auto-ui-history-thinking-toggle",
      "title": "历史会话思考过程可折叠",
      "purpose": "确认每条助手回复提供「查看思考过程」按钮，再次点击可隐藏中间 JSON/工具步骤。",
      "method": "GET",
      "path": "/styles.css",
      "input": null,
      "expect": {
        "status": 200,
        "bodyContains": [
          ".history-thinking-toggle",
          ".history-thinking-panel",
          ".history-thinking-entry-body"
        ]
      }
    }
  ]
}
