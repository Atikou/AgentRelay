{
  "milestone": "M3",
  "feature": "计划模式",
  "featureId": "m3-plan",
  "summary": "验证 Planner 入口 /api/plan 的请求校验（仅测不依赖模型的错误路径）。",
  "cases": [
    {
      "id": "m3-plan-empty-goal",
      "title": "空 goal 返回 400",
      "purpose": "确认计划模式必须提供非空目标，防止向模型发送无效请求。",
      "method": "POST",
      "path": "/api/plan",
      "input": { "goal": "" },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m3-plan-unknown-client",
      "title": "未知模型客户端返回 404",
      "purpose": "确认计划模式指定不存在的 clientName 时返回明确错误，不会误走默认路由。",
      "method": "POST",
      "path": "/api/plan",
      "input": { "goal": "生成一个只读计划", "clientName": "missing-client" },
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m3-plan-reject-report-prompt",
      "title": "报告型计划提示返回契约错误",
      "purpose": "确认 /api/plan 遇到 Markdown 报告型计划提示时提前返回 PLAN_REPORT_REQUEST，不再进入模型调用后报 JSON 解析失败。",
      "method": "POST",
      "path": "/api/plan",
      "input": {
        "goal": "# 计划模式分析结果\n\n## 1. 目标理解\n\n本次仅生成计划，未修改任何文件。"
      },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error", "code", "suggestedEndpoint"],
        "bodyPaths": {
          "code": "PLAN_REPORT_REQUEST",
          "suggestedEndpoint": "/api/agent"
        }
      }
    },
    {
      "id": "m3-plan-analyze-empty-goal",
      "title": "计划报告分析空 goal 返回 400",
      "purpose": "确认 UserVisiblePlan 分析入口在 goal 为空时直接拒绝，不进入模型计划报告链路。",
      "method": "POST",
      "path": "/api/plans/analyze",
      "input": { "goal": "" },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m3-plan-compile-empty-confirmed-todos",
      "title": "编译计划缺 confirmedTodoIds 返回 400",
      "purpose": "确认 UserVisiblePlan 不能在未确认 Todo 范围时被编译为内部执行计划草案。",
      "method": "POST",
      "path": "/api/plans/uvp_missing/compile",
      "input": { "confirmedTodoIds": [] },
      "expect": {
        "status": 400,
        "bodyHasKeys": ["error"]
      }
    },
    {
      "id": "m3-plan-compile-missing-visible-plan",
      "title": "不存在的 UserVisiblePlan 编译返回 404",
      "purpose": "确认 PlanCompiler 只能从已保存的 UserVisiblePlan 编译，不能凭空把用户输入当执行源。",
      "method": "POST",
      "path": "/api/plans/uvp_missing/compile",
      "input": { "confirmedTodoIds": ["todo-1"] },
      "expect": {
        "status": 404,
        "bodyHasKeys": ["error", "code"]
      }
    }
  ]
}
