{
  "workspaceRoot": "..",
  "models": {
    "default": "local-qwen35",
    "clients": [
      {
        "name": "local-qwen35",
        "provider": "ollama",
        "location": "local",
        "baseUrl": "http://localhost:11434",
        "model": "qwen3.5:0.8b",
        "think": false,
        "routerProfile": {
          "defaultLevel": 1,
          "relativeCost": "free",
          "canDraft": true,
          "canReview": false,
          "allowedRoles": ["primary", "draft"]
        }
      },
      {
        "name": "local-phi4",
        "provider": "ollama",
        "location": "local",
        "baseUrl": "http://localhost:11434",
        "model": "phi4",
        "think": false,
        "routerProfile": {
          "defaultLevel": 3,
          "relativeCost": "free",
          "canDraft": true,
          "canReview": true,
          "canFinal": true,
          "allowedRoles": ["primary", "draft", "review", "final"]
        }
      },
      {
        "name": "local-qwen25vl",
        "provider": "ollama",
        "location": "local",
        "baseUrl": "http://localhost:11434",
        "model": "qwen2.5vl:7b",
        "think": false,
        "routerProfile": {
          "displayName": "Qwen2.5-VL 7B",
          "defaultLevel": 3,
          "relativeCost": "free",
          "supportsVision": true,
          "canDraft": true,
          "canReview": true,
          "allowedRoles": ["primary", "draft", "review"]
        }
      },
      {
        "name": "local-lmstudio",
        "provider": "openai-compatible",
        "location": "local",
        "baseUrl": "http://localhost:1234/v1",
        "apiKey": "lm-studio",
        "model": "local-model"
      },
      {
        "name": "cloud-openai",
        "provider": "openai-compatible",
        "location": "remote",
        "baseUrl": "https://api.openai.com/v1",
        "apiKeyEnv": "OPENAI_API_KEY",
        "model": "gpt-4o-mini",
        "pricePer1kInputUsd": 0.00015,
        "pricePer1kOutputUsd": 0.0006
      },
      {
        "name": "cloud-deepseek",
        "provider": "openai-compatible",
        "location": "remote",
        "baseUrl": "https://api.deepseek.com/v1",
        "apiKeyEnv": "OPENAI_API_KEY",
        "model": "deepseek-chat",
        "pricePer1kInputUsd": 0.00027,
        "pricePer1kOutputUsd": 0.0011
      },
      {
        "name": "cloud-anthropic",
        "provider": "anthropic",
        "location": "remote",
        "baseUrl": "https://api.anthropic.com",
        "apiKeyEnv": "ANTHROPIC_API_KEY",
        "model": "claude-3-5-sonnet-latest",
        "maxTokens": 4096,
        "pricePer1kInputUsd": 0.003,
        "pricePer1kOutputUsd": 0.015,
        "routerProfile": {
          "defaultLevel": 3,
          "relativeCost": "high",
          "supportsVision": true,
          "canDraft": true,
          "canReview": true,
          "allowedRoles": ["primary", "review", "final"]
        }
      }
    ]
  },
  "routing": {
    "strategy": "local-first",
    "fallback": true
  },
  "scheduler": {
    "unattendedGoalPatterns": [],
    "gitPollIntervalMs": 5000,
    "cronMissPolicy": "skip",
    "dailySummaryCron": "0 9 * * *",
    "dailySummaryGoal": "生成昨日工作区变更与未消费通知的简要摘要（只读分析，不执行写操作）"
  },
  "security": {
    "shell": {
      "denyCommands": [],
      "allowCommands": []
    }
  }
}
