{
  "workspaceRoot": "..",
  "models": {
    "default": "cloud-openai",
    "clients": [
      {
        "name": "cloud-openai",
        "provider": "openai-compatible",
        "location": "remote",
        "baseUrl": "https://api.openai.com/v1",
        "apiKeyEnv": "OPENAI_API_KEY",
        "model": "gpt-4o-mini"
      },
      {
        "name": "cloud-deepseek",
        "provider": "openai-compatible",
        "location": "remote",
        "baseUrl": "https://api.deepseek.com/v1",
        "apiKeyEnv": "OPENAI_API_KEY",
        "model": "deepseek-chat"
      },
      {
        "name": "cloud-anthropic",
        "provider": "anthropic",
        "location": "remote",
        "baseUrl": "https://api.anthropic.com",
        "apiKeyEnv": "ANTHROPIC_API_KEY",
        "model": "claude-3-5-sonnet-latest",
        "maxTokens": 4096
      },
      {
        "name": "local-qwen35",
        "provider": "ollama",
        "location": "local",
        "baseUrl": "http://localhost:11434",
        "model": "qwen3.5:0.8b",
        "think": false
      },
      {
        "name": "local-phi4",
        "provider": "ollama",
        "location": "local",
        "baseUrl": "http://localhost:11434",
        "model": "phi4",
        "think": false
      }
    ]
  },
  "routing": {
    "strategy": "cloud-first",
    "fallback": true
  }
}
