# 远程模型 API Key（按需配置，未配置的远程客户端会在启动检查时标记为不可用）

# OpenAI 兼容协议的 key（OpenAI 官方，或 DeepSeek 等任意 OpenAI 兼容服务）
# DeepSeek 兼容 OpenAI 协议，直接把 DeepSeek key 填到这里即可，无需单独变量。
OPENAI_API_KEY=

# Anthropic（Claude）原生 /v1/messages 协议
ANTHROPIC_API_KEY=

# 可选：覆盖默认 profile（default / local-only / cloud）
AGENT_PROFILE=default

# 可选：HTTP 服务端口（默认 18787）
PORT=18787
